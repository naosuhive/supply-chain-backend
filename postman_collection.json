    {
      "name": "Inventory",
      "description": "Retailer inventory APIs using the exact Excel inventory fields. Listing responses are grid-ready and do not require frontend mapping. These requests require a retailer JWT because the inventory dataset belongs to the retailer.",
      "item": [
        {
          "name": "List Inventory Items",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/inventory",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "inventory"
              ]
            },
            "description": "Returns the full inventory list with the exact Excel columns for direct frontend grid rendering."
          },
          "response": []
        },
        {
          "name": "Search Inventory Items",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/inventory/search?itemName={{inventorySearchItemName}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "inventory",
                "search"
              ],
              "query": [
                {
                  "key": "itemName",
                  "value": "{{inventorySearchItemName}}"
                }
              ]
            },
            "description": "Searches retailer inventory by itemName using case-insensitive partial matching. Returns the same grid-ready inventory row structure as the list API."
          },
          "response": []
        },
        {
          "name": "Get Inventory Item By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/inventory/{{inventoryItemId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "inventory",
                "{{inventoryItemId}}"
              ]
            },
            "description": "Returns one inventory item using the exact Excel field structure."
          },
          "response": []
        },
        {
          "name": "Create Inventory Item",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"itemId\": 200,\n  \"itemCode\": \"PL000200\",\n  \"itemName\": \"Test item\",\n  \"itemDescription\": \"Inventory item created from Postman\",\n  \"itemType\": \"PVC\",\n  \"itemSize\": \"2 inch\",\n  \"category\": \"Plumbing\",\n  \"subCategory\": \"Fittings\",\n  \"supplierName\": \"test-supplier\",\n  \"unitMeasurementType\": \"pieces\",\n  \"unitName\": \"boxes\",\n  \"quantity\": 0,\n  \"unitPrice\": 0,\n  \"discount\": 0\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/inventory",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "inventory"
              ]
            },
            "description": "Creates an inventory item using only the Excel field set. No basePrice or directSalePrice fields are used."
          },
          "response": []
        },
        {
          "name": "Update Inventory Item",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"itemId\": {{inventoryItemId}},\n  \"itemCode\": \"PL00001\",\n  \"itemName\": \"Lbow\",\n  \"itemDescription\": \"1/2'' pvc lbow\",\n  \"itemType\": \"PVC\",\n  \"itemSize\": \"1/2 inch\",\n  \"category\": \"Plumbing\",\n  \"subCategory\": \"Fittings\",\n  \"supplierName\": \"waterflo\",\n  \"unitMeasurementType\": \"pieces\",\n  \"unitName\": \"bags\",\n  \"quantity\": 0,\n  \"unitPrice\": 0,\n  \"discount\": 0\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/inventory/{{inventoryItemId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "inventory",
                "{{inventoryItemId}}"
              ]
            },
            "description": "Updates one inventory item using the same field structure as the Excel dataset."
          },
          "response": []
        },
        {
          "name": "Delete Inventory Item",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/inventory/{{inventoryItemId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "inventory",
                "{{inventoryItemId}}"
              ]
            },
            "description": "Deletes an inventory item by itemId."
          },
          "response": []
        }
      ]
    },
    {
      "name": "User Registration (3-Step Flow)",
      "description": "Complete user registration with email verification. Required for all new user signups.",
      "item": [
        {
          "name": "Step 1: Send Registration OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/send-registration-otp",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "send-registration-otp"
              ]
            },
            "description": "Send OTP to the user's email for registration verification."
          },
          "response": []
        },
        {
          "name": "Step 2: Verify Registration OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"user@example.com\",\n  \"otpCode\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/verify-registration-otp",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "verify-registration-otp"
              ]
            },
            "description": "Verify the OTP received during registration."
          },
          "response": []
        },
        {
          "name": "Step 3: Complete Customer Registration (Without Address)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"customer_user\",\n  \"email\": \"customer@example.com\",\n  \"phoneNumber\": \"+1234567890\",\n  \"password\": \"securePassword123\",\n  \"role\": \"ROLE_CUSTOMER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Complete customer registration after OTP verification."
          },
          "response": []
        },
        {
          "name": "Step 3: Complete Customer Registration (With Address)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"customer_user_with_address\",\n  \"email\": \"customer_with_address@example.com\",\n  \"phoneNumber\": \"+1234567895\",\n  \"password\": \"securePassword123\",\n  \"role\": \"ROLE_CUSTOMER\",\n  \"address\": {\n    \"line1\": \"123 Main St\",\n    \"city\": \"New York\",\n    \"state\": \"NY\",\n    \"country\": \"USA\",\n    \"postalCode\": \"10001\",\n    \"isPrimary\": true\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Complete customer registration with an initial address."
          },
          "response": []
        },
        {
          "name": "Step 3: Complete Manufacturer Registration",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"manufacturer_user\",\n  \"email\": \"manufacturer@example.com\",\n  \"phoneNumber\": \"+1234567891\",\n  \"password\": \"securePassword123\",\n  \"role\": \"ROLE_MANUFACTURER\",\n  \"companyName\": \"ACME Manufacturing Co.\",\n  \"gstNumber\": \"GST123456789\",\n  \"businessType\": \"Electronics\",\n  \"address\": {\n    \"line1\": \"456 Industrial Ave\",\n    \"city\": \"Detroit\",\n    \"state\": \"MI\",\n    \"country\": \"USA\",\n    \"postalCode\": \"48201\",\n    \"isPrimary\": true\n  }\n}"
            },
            "url": {
