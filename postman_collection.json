{
	"info": {
		"_postman_id": "supply-chain-ui-integration",
		"name": "Supply Chain Management - UI Integration API",
		"description": "Production-ready API collection for UI team integration. Contains all essential endpoints for user authentication, registration, and password management.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "User Registration (3-Step Flow)",
			"description": "Complete user registration with email verification. Required for all new user signups.",
			"item": [
				{
					"name": "Step 1: Send Registration OTP",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user@example.com\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/send-registration-otp",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "send-registration-otp"]
						},
						"description": "Send OTP to user's email for registration verification"
					},
					"response": []
				},
				{
					"name": "Step 2: Verify Registration OTP",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"identifier\": \"user@example.com\",\n  \"otpCode\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/verify-registration-otp",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "verify-registration-otp"]
						},
						"description": "Verify OTP received via email. Must be successful before proceeding to step 3."
					},
					"response": []
				},
				{
					"name": "Step 3: Complete Customer Registration (Without Address)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"customer_user\",\n  \"email\": \"customer@example.com\",\n  \"phoneNumber\": \"+1234567890\",\n  \"password\": \"securePassword123\",\n  \"role\": \"ROLE_CUSTOMER\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "register"]
						},
						"description": "Complete customer registration without address. Email must be verified in step 2. Address can be added later."
					},
					"response": []
				},
				{
					"name": "Step 3: Complete Customer Registration (With Address)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"customer_user_with_address\",\n  \"email\": \"customer_with_address@example.com\",\n  \"phoneNumber\": \"+1234567895\",\n  \"password\": \"securePassword123\",\n  \"role\": \"ROLE_CUSTOMER\",\n  \"address\": {\n    \"line1\": \"123 Main St\",\n    \"city\": \"New York\",\n    \"state\": \"NY\",\n    \"country\": \"USA\",\n    \"postalCode\": \"10001\",\n    \"isPrimary\": true\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "register"]
						},
						"description": "Complete customer registration with address. Email must be verified in step 2."
					},
					"response": []
				},
				{
					"name": "Step 3: Complete Manufacturer Registration",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"manufacturer_user\",\n  \"email\": \"manufacturer@example.com\",\n  \"phoneNumber\": \"+1234567891\",\n  \"password\": \"securePassword123\",\n  \"role\": \"ROLE_MANUFACTURER\",\n  \"companyName\": \"ACME Manufacturing Co.\",\n  \"gstNumber\": \"GST123456789\",\n  \"businessType\": \"Electronics\",\n  \"address\": {\n    \"line1\": \"456 Industrial Ave\",\n    \"city\": \"Detroit\",\n    \"state\": \"MI\",\n    \"country\": \"USA\",\n    \"postalCode\": \"48201\",\n    \"isPrimary\": true\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "register"]
						},
						"description": "Complete manufacturer registration. Email must be verified in step 2. companyName is required field."
					},
					"response": []
				},
				{
					"name": "Step 3: Complete Retailer Registration",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"retailer_user\",\n  \"email\": \"retailer@example.com\",\n  \"phoneNumber\": \"+1234567892\",\n  \"password\": \"securePassword123\",\n  \"role\": \"ROLE_RETAILER\",\n  \"businessName\": \"Best Retail Store\",\n  \"gstNumber\": \"GST987654321\",\n  \"storeType\": \"Electronics\",\n  \"address\": {\n    \"line1\": \"789 Shopping Blvd\",\n    \"city\": \"Los Angeles\",\n    \"state\": \"CA\",\n    \"country\": \"USA\",\n    \"postalCode\": \"90001\",\n    \"isPrimary\": true\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "register"]
						},
						"description": "Complete retailer registration. Email must be verified in step 2. businessName is required field."
					},
					"response": []
				}
			]
		},
		{
			"name": "User Authentication",
			"description": "User login and authentication endpoints.",
			"item": [
				{
					"name": "Login with Password",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"usernameOrEmail\": \"username_or_email\",\n  \"password\": \"user_password\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "login"]
						},
						"description": "Login using username/email and password. Returns JWT token for authenticated sessions."
					},
					"response": []
				},
				{
					"name": "Login with OTP (Step 1: Send OTP)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"identifier\": \"username_or_email_or_phone\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/send-login-otp",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "send-login-otp"]
						},
						"description": "Send OTP for passwordless login. Can use username, email, or phone number."
					},
					"response": []
				},
				{
					"name": "Login with OTP (Step 2: Verify OTP)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"identifier\": \"username_or_email_or_phone\",\n  \"otpCode\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/verify-login-otp",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "verify-login-otp"]
						},
						"description": "Verify OTP for passwordless login. Returns JWT token for authenticated sessions."
					},
					"response": []
				}
			]
		},
		{
			"name": "Address Management",
			"description": "Address CRUD operations for authenticated users. JWT token required in Authorization header.",
			"item": [
				{
					"name": "reate Address",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{jwtToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"line1\": \"123 Main St\",\n  \"line2\": \"Apt 4B\",\n  \"city\": \"New York\",\n  \"state\": \"NY\",\n  \"country\": \"USA\",\n  \"postalCode\": \"10001\",\n  \"addressType\": \"SHIPPING\",\n  \"isPrimary\": true\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/addresses",
							"host": ["{{baseUrl}}"],
							"path": ["api", "addresses"]
						},
						"description": "Create a new address for the authenticated user. addressType: SHIPPING, BILLING, BUSINESS"
					},
					"response": []
				},
				{
					"name": "Get User Addresses",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwtToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/addresses",
							"host": ["{{baseUrl}}"],
							"path": ["api", "addresses"]
						},
						"description": "Get all addresses for the authenticated user."
					},
					"response": []
				},
				{
					"name": "Update Address",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{jwtToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"line1\": \"456 Updated St\",\n  \"line2\": \"Suite 100\",\n  \"city\": \"Los Angeles\",\n  \"state\": \"CA\",\n  \"country\": \"USA\",\n  \"postalCode\": \"90001\",\n  \"addressType\": \"BILLING\",\n  \"isPrimary\": false\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/addresses/{{addressId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "addresses", "{{addressId}}"]
						},
						"description": "Update an existing address. Replace {{addressId}} with actual address ID."
					},
					"response": []
				},
				{
					"name": "Delete Address",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwtToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/addresses/{{addressId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "addresses", "{{addressId}}"]
						},
						"description": "Delete an address. Replace {{addressId}} with actual address ID."
					},
					"response": []
				}
			]
		},
		{
			"name": "Password Management",
			"description": "Password reset and recovery endpoints.",
			"item": [
				{
					"name": "Send Forgot Password OTP",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"identifier\": \"username_or_email_or_phone\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/send-forgot-password-otp",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "send-forgot-password-otp"]
						},
						"description": "Send OTP for password reset. User must exist in system."
					},
					"response": []
				},
				{
					"name": "Reset Password with OTP",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"identifier\": \"username_or_email_or_phone\",\n  \"otpCode\": \"123456\",\n  \"newPassword\": \"newSecurePassword123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/reset-password",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "reset-password"]
						},
						"description": "Reset password using OTP verification. New password must be at least 6 characters."
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string",
			"description": "Base URL for the API endpoints"
		},
		{
			"key": "jwtToken",
			"value": "",
			"type": "string",
			"description": "JWT token from login response for authenticated requests"
		},
		{
			"key": "addressId",
			"value": "",
			"type": "string",
			"description": "Address ID for update/delete operations"
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	]
}
