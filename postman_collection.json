{
  "info": {
    "_postman_id": "supply-chain-management-api",
    "name": "Supply Chain Management API",
    "description": "Complete API collection for Supply Chain Management, including authentication, addresses, products, manufacturer and retailer operations, and orders.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "REST API Basics: CRUD, Tests & Variables",
      "description": "Starter examples showing REST API basics in Postman: create, read, update, delete, request tests, and collection variables.",
      "item": [
        {
          "name": "Variables Demo: Login And Save JWT",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login request succeeds\", function () {",
                  "  pm.expect(pm.response.code).to.eql(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (data && data.token) {",
                  "  pm.collectionVariables.set(\"jwtToken\", data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usernameOrEmail\": \"{{loginIdentifier}}\",\n  \"password\": \"{{loginPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Uses collection variables and saves the returned JWT token into `jwtToken` for later requests."
          },
          "response": []
        },
        {
          "name": "CRUD Create: Add Address",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Create address succeeds\", function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (data && data.id) {",
                  "  pm.collectionVariables.set(\"addressId\", data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"line1\": \"101 Market Street\",\n  \"line2\": \"Floor 2\",\n  \"city\": \"San Francisco\",\n  \"state\": \"CA\",\n  \"country\": \"USA\",\n  \"postalCode\": \"94105\",\n  \"addressType\": \"SHIPPING\",\n  \"isPrimary\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/addresses",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "addresses"
              ]
            },
            "description": "POST example. Creates an address and saves the returned `id` into the `addressId` collection variable."
          },
          "response": []
        },
