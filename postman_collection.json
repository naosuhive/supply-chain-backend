              "raw": "{\n  \"username\": \"retailer_user\",\n  \"email\": \"retailer@example.com\",\n  \"phoneNumber\": \"+1234567892\",\n  \"password\": \"securePassword123\",\n  \"role\": \"ROLE_RETAILER\",\n  \"businessName\": \"Best Retail Store\",\n  \"gstNumber\": \"GST987654321\",\n  \"storeType\": \"Electronics\",\n  \"address\": {\n    \"line1\": \"789 Shopping Blvd\",\n    \"city\": \"Los Angeles\",\n    \"state\": \"CA\",\n    \"country\": \"USA\",\n    \"postalCode\": \"90001\",\n    \"isPrimary\": true\n  }\n}"
            },
