		{
			"name": "Manufacturers",
			"item": [
				{
					"name": "Create Product",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{jwtToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"productName\": \"Laptop\",\n  \"category\": \"Electronics\",\n  \"subcategory\": \"Computers\",\n  \"brand\": \"Dell\",\n  \"unitOfMeasure\": \"pieces\",\n  \"specifications\": \"Intel i7, 16GB RAM, 512GB SSD\",\n  \"stock\": 100,\n  \"basePrice\": 999.99,\n  \"directSalePrice\": 1099.99\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/manufacturer/products",
							"host": ["{{baseUrl}}"],
							"path": ["api", "manufacturer", "products"]
						}
					},
					"response": []
				},
				{
					"name": "List Products",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwtToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/manufacturer/products",
							"host": ["{{baseUrl}}"],
							"path": ["api", "manufacturer", "products"]
						}
					},
					"response": []
				},
				{
					"name": "Update Product",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{jwtToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"stock\": 150,\n  \"basePrice\": 899.99,\n  \"directSalePrice\": 999.99,\n  \"isActive\": true\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/manufacturer/products/{{productId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "manufacturer", "products", "{{productId}}"]
						}
					},
					"response": []
				}
			]
